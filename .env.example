# ── Required for correct multi-tenant isolation ──────────────────────────────

# Your node's full 64-char hex node ID.
# CRITICAL: Set this. Without it, the vault cannot distinguish local from foreign
# callers and will fail-closed (all network callers get scoped, not blocked, but
# your own bot may lose access if the API fallback also fails).
# Find it: knarr status | grep node_id   OR   curl -sk https://localhost:8080/api/status
KNARR_NODE_ID=

# Cockpit API URL — used as fallback if KNARR_NODE_ID is not set.
# Spawn nodes (HTTP cockpit): http://127.0.0.1:8080
# Custom nodes with TLS:       https://127.0.0.1:8080
KNARR_API_URL=https://127.0.0.1:8080

# Cockpit auth token — from [cockpit] auth_token in knarr.toml
KNARR_API_TOKEN=

# ── Storage ───────────────────────────────────────────────────────────────────

# Root directory for all vault data. Default: /opt/knarr-vault
VAULT_ROOT=/opt/knarr-vault

# Per-foreign-node storage quota (bytes). Default: 100MB
# VAULT_QUOTA_BYTES=104857600

# Per-foreign-node document count quota. Default: 1000
# VAULT_QUOTA_DOCS=1000

# Max binary upload size (bytes). Default: 10MB
# VAULT_MAX_UPLOAD_BYTES=10485760

# ── Multi-vault channel routing (optional) ───────────────────────────────────

# Map Telegram chat IDs to named vaults.
# Format: "chat_id_1:vault_name,chat_id_2:vault_name"
# Example: VAULT_CHANNEL_MAP="-100123456:sales,-100789012:personal"
# VAULT_CHANNEL_MAP=

# ── Write notifications (optional) ───────────────────────────────────────────

# Telegram bot token + chat to notify on high-value writes
# VAULT_NOTIFY_BOT_TOKEN=
# VAULT_NOTIFY_CHAT_ID=
# VAULT_NOTIFY_RULES=value>5000;status=closed-won

# ── Semantic search (optional, requires zvec + Gemini API key) ───────────────
# GEMINI_API_KEY=
